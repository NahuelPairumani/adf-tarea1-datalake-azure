{
	"name": "df_venta_online_bronze_silver",
	"properties": {
		"folder": {
			"name": "Bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ventas_online_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ventas_online_limpia_csv",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "filter1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          order_id as string,",
				"          timestamp as string,",
				"          product as string,",
				"          qty as string,",
				"          unit_price as string,",
				"          {customer/name} as string,",
				"          {customer/email} as string,",
				"          {customer/city} as string,",
				"          payment_method as string,",
				"          status as string,",
				"          shipping_cost as string,",
				"          channel as string,",
				"          customer as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(product = trim(product),",
				"          timestamp = trim(timestamp),",
				"          {customer/name} = trim({customer/name}),",
				"          {customer/email} = trim({customer/email}),",
				"          {customer/city} = trim({customer/city}),",
				"          order_id = trim(order_id),",
				"          qty = trim(qty),",
				"          unit_price = trim(unit_price),",
				"          payment_method = trim(payment_method),",
				"          status = trim(status),",
				"          shipping_cost = trim(shipping_cost),",
				"          channel = trim(channel),",
				"          customer = trim(customer)) ~> derivedColumn1",
				"derivedColumn1 derive(product = initCap(regexReplace(product,'\\\\s+',' ')),",
				"          {customer/name} = initCap(regexReplace({customer/name},'\\\\s+',' '))) ~> derivedColumn2",
				"derivedColumn2 derive({customer/city} = iif(in(['SCZ','Santa Cruz','Sta Cruz','santa cruz','SANTA CRUZ','Sta. Cruz','SC'], {customer/city}), 'Santa Cruz',\r",
				"iif(in(['LPZ','La Paz','la paz','LA PAZ','L.P.','LP'], {customer/city}), 'La Paz',\r",
				"iif(in(['CBBA','Cochabamba','cochabamba','COCHABAMBA','CBB','CB'], {customer/city}), 'Cochabamba',\r",
				"iif(in(['ORU','Oruro','oruro','ORURO','OR'], {customer/city}), 'Oruro',\r",
				"iif(in(['PTS','Potosi','potosi','POTOSI','Potosí','potosí','PT'], {customer/city}), 'Potosí',\r",
				"iif(in(['TJA','Tarija','tarija','TARIJA','TJ'], {customer/city}), 'Tarija',\r",
				"iif(in(['CHQ','Chuquisaca','chuquisaca','CHUQUISACA','Sucre','sucre','SUC','CH'], {customer/city}), 'Chuquisaca',\r",
				"iif(in(['BEN','Beni','beni','BENI','BN'], {customer/city}), 'Beni',\r",
				"iif(in(['PND','Pando','pando','PANDO','PN'], {customer/city}), 'Pando', \r",
				"{customer/city})))))))))) ~> derivedColumn3",
				"derivedColumn3 derive(unit_price = toFloat(regexReplace(toString(unit_price),'[^0-9.]','')),",
				"          shipping_cost = toInteger(shipping_cost),",
				"          qty = toInteger(qty)) ~> derivedColumn4",
				"derivedColumn4 derive(timestamp = coalesce(\r",
				"    toDate(timestamp, 'dd \\'de\\' MMMM \\'de\\' yyyy'),\r",
				"    toDate(timestamp, 'MMMM dd, yyyy'),\r",
				"    toDate(timestamp, 'yyyy-MM-dd'),\r",
				"    toDate(timestamp, 'dd-MM-yyyy'),\r",
				"    toDate(timestamp, 'MM-dd-yyyy'),\r",
				"    toDate(timestamp, 'dd/MM/yyyy'),\r",
				"    toDate(timestamp, 'yyyy/MM/dd'),\r",
				"    toDate(timestamp, 'dd/MMM/yyyy'),\r",
				"    toDate(timestamp, 'dd-MMM-yyyy')\r",
				")) ~> derivedColumn5",
				"derivedColumn5 filter(unit_price>0 && shipping_cost>0 && !isNull(qty) && !isNull(unit_price) && !isNull(shipping_cost) && !isNull(timestamp)) ~> filter1",
				"filter1 select(mapColumn(",
				"          id_venta = order_id,",
				"          fecha = timestamp,",
				"          producto = product,",
				"          cantidad = qty,",
				"          precio_unitario = unit_price,",
				"          cliente_nombre = {customer/name},",
				"          cliente_email = {customer/email},",
				"          sucursal = {customer/city},",
				"          metodo_pago = payment_method,",
				"          estado = status,",
				"          costo_envio = shipping_cost,",
				"          canal = channel,",
				"          cliente_nombre = customer",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_venta as string,",
				"          fecha as string,",
				"          producto as string,",
				"          cantidad as string,",
				"          precio_unitario as string,",
				"          sucursal as string,",
				"          vendedor as string,",
				"          cliente_nombre as string,",
				"          cliente_email as string,",
				"          metodo_pago as string,",
				"          canal as string",
				"     ),",
				"     partitionFileNames:['ventas_online_limpio.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}